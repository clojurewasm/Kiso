{
  "name": "@clojurewasm/kiso",
  "version": "0.1.0",
  "description": "ClojureScript-to-JavaScript compiler in TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime/index.js",
    "./runtime/string": "./dist/runtime/string.js",
    "./runtime/set": "./dist/runtime/set.js",
    "./runtime/walk": "./dist/runtime/walk.js",
    "./vite": "./dist/api/vite-plugin.js",
    "./compiler": "./dist/api/compiler.js",
    "./codegen": "./dist/api/codegen-hooks.js"
  },
  "bin": {
    "kiso": "./bin/kiso.mjs"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clojurewasm/Kiso.git",
    "directory": "packages/kiso"
  },
  "homepage": "https://github.com/clojurewasm/Kiso",
  "author": "chaploud",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3"
  }
}
